# URL окружений для каждого сервиса
# Формат: VITE_SVC_<SERVICE_ID>_<ENV>=<URL>
# SERVICE_ID — id сервиса из services.index.json, в UPPER_SNAKE_CASE (auth-service → AUTH_SERVICE)

VITE_SVC_AUTH_SERVICE_DEV=http://localhost:8081
VITE_SVC_AUTH_SERVICE_STAGING=https://auth.staging.internal
VITE_SVC_AUTH_SERVICE_PROD=https://auth.internal

VITE_SVC_SOCIAL_SERVICE_DEV=http://localhost:8085/api/v2
VITE_SVC_SOCIAL_SERVICE_STAGING=https://social.staging.internal
VITE_SVC_SOCIAL_SERVICE_PROD=https://social.internal

VITE_SVC_NOTIFICATION_SERVICE_DEV=http://localhost:8083
VITE_SVC_NOTIFICATION_SERVICE_STAGING=https://notifications.staging.internal
VITE_SVC_NOTIFICATION_SERVICE_PROD=https://notifications.internal
