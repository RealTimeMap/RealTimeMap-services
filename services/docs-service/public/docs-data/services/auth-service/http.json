{
  "endpoints": [
    {
      "id": "register",
      "method": "POST",
      "path": "/api/v2/auth/register",
      "summary": "Регистрация нового пользователя",
      "description": "Создаёт новый аккаунт пользователя. Возвращает данные созданного пользователя.",
      "tags": ["Auth"],
      "requestBody": {
        "description": "Данные для регистрации",
        "contentType": "json",
        "schema": [
          { "name": "email", "type": "string", "required": true, "description": "Email пользователя" },
          { "name": "password", "type": "string", "required": true, "description": "Пароль (мин. 8 символов)" },
          { "name": "username", "type": "string", "required": true, "description": "Имя пользователя" }
        ],
        "example": {
          "email": "user@example.com",
          "password": "secretPass123",
          "username": "john_doe"
        }
      },
      "responses": [
        {
          "statusCode": 201,
          "description": "Пользователь успешно зарегистрирован",
          "schema": [
            { "name": "id", "type": "integer", "required": true, "description": "ID пользователя" },
            { "name": "email", "type": "string", "required": true, "description": "Email пользователя" },
            { "name": "is_active", "type": "boolean", "required": true, "description": "Активен ли аккаунт" },
            { "name": "is_superuser", "type": "boolean", "required": true, "description": "Является ли суперпользователем" },
            { "name": "is_verified", "type": "boolean", "required": true, "description": "Подтверждён ли email" },
            { "name": "phone", "type": "string", "required": false, "description": "Номер телефона" },
            { "name": "username", "type": "string", "required": true, "description": "Имя пользователя" },
            { "name": "avatar", "type": "string", "required": false, "description": "URL аватара" }
          ],
          "example": {
            "id": 60,
            "email": "user@example.com",
            "is_active": true,
            "is_superuser": false,
            "is_verified": false,
            "phone": null,
            "username": "john_doe",
            "avatar": null
          }
        }
      ],
      "errors": ["validation-error", "conflict"]
    },
    {
      "id": "login",
      "method": "POST",
      "path": "/api/v2/auth/login",
      "summary": "Вход в систему",
      "description": "Аутентификация пользователя по email и паролю. Возвращает access token.",
      "tags": ["Auth"],
      "requestBody": {
        "description": "Данные для входа",
        "contentType": "x-www-form-urlencoded",
        "schema": [
          { "name": "username", "type": "string", "required": true, "description": "username пользователя" },
          { "name": "password", "type": "string", "required": true, "description": "Пароль" }
        ],
        "example": {
          "username": "user",
          "password": "secretPass123"
        }
      },
      "responses": [
        {
          "statusCode": 200,
          "description": "Успешная аутентификация",
          "schema": [
            { "name": "accessToken", "type": "string", "required": true, "description": "JWT access token" },
            { "name": "tokenType", "type": "string", "required": true, "description": "Тип токена (bearer)" }
          ],
          "example": {
            "accessToken": "eyJhbGciOiJIUzI1NiIs...",
            "tokenType": "bearer"
          }
        }
      ],
      "errors": ["validation-error", "unauthorized"]
    },
    {
      "id": "token-validate",
      "method": "GET",
      "path": "/api/v2/auth/token-validate",
      "summary": "Валидация токена",
      "description": "Проверяет валидность Bearer токена. Используется Traefik forwardAuth middleware. При успехе возвращает заголовки X-User-Id, X-User-Name, X-User-Ban, X-User-Admin. Служит для внутрисервисной связи.",
      "tags": ["Auth"],
      "auth": true,
      "parameters": [],
      "responses": [
        {
          "statusCode": 200,
          "description": "Токен валиден"
        },
        {
          "statusCode": 401,
          "description": "Токен невалиден или истёк"
        }
      ],
      "errors": ["unauthorized"]
    }
  ]
}
