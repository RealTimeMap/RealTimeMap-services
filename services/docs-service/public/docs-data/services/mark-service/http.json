{
  "endpoints": [
    {
      "id": "get-marks",
      "method": "POST",
      "path": "/api/v2/marks/",
      "summary": "Получение меток в области карты",
      "description": "Возвращает метки или кластеры меток в заданной видимой области карты. При zoomLevel < 12 возвращает кластеры, при >= 12 — отдельные метки. Фильтрация по временному диапазону событий.",
      "tags": ["Метки"],
      "requestBody": {
        "description": "Параметры области и фильтрации",
        "contentType": "json",
        "schema": [
          {
            "name": "screen",
            "type": "object",
            "required": true,
            "description": "Видимая область карты",
            "children": [
              {
                "name": "leftTop",
                "type": "object",
                "required": true,
                "description": "Левый верхний угол области",
                "children": [
                  { "name": "lon", "type": "number", "required": true, "description": "Долгота (-180 до 180)" },
                  { "name": "lat", "type": "number", "required": true, "description": "Широта (-90 до 90)" }
                ]
              },
              {
                "name": "center",
                "type": "object",
                "required": true,
                "description": "Центр области",
                "children": [
                  { "name": "lon", "type": "number", "required": true, "description": "Долгота" },
                  { "name": "lat", "type": "number", "required": true, "description": "Широта" }
                ]
              },
              {
                "name": "rightBottom",
                "type": "object",
                "required": true,
                "description": "Правый нижний угол области",
                "children": [
                  { "name": "lon", "type": "number", "required": true, "description": "Долгота" },
                  { "name": "lat", "type": "number", "required": true, "description": "Широта" }
                ]
              }
            ]
          },
          { "name": "zoomLevel", "type": "integer", "required": false, "description": "Уровень зума карты. По умолчанию 15. При < 12 возвращаются кластеры, при >= 12 — метки" },
          { "name": "startAt", "type": "string", "required": true, "description": "Начало временного диапазона (ISO 8601 / RFC3339)" },
          { "name": "endAt", "type": "string", "required": false, "description": "Конец временного диапазона. По умолчанию — текущее время UTC" }
        ],
        "example": {
          "screen": {
            "leftTop": { "lon": 37.5, "lat": 55.8 },
            "center": { "lon": 37.6, "lat": 55.75 },
            "rightBottom": { "lon": 37.7, "lat": 55.7 }
          },
          "zoomLevel": 15,
          "startAt": "2026-04-25T00:00:00Z"
        }
      },
      "responses": [
        {
          "statusCode": 200,
          "description": "Список меток (при zoomLevel >= 12). Возвращается краткая форма метки — для деталей используйте `GET /api/v2/marks/{markID}`",
          "schema": [
            { "name": "id", "type": "integer", "required": true, "description": "ID метки" },
            { "name": "markName", "type": "string", "required": true, "description": "Название метки" },
            {
              "name": "geom",
              "type": "object",
              "required": true,
              "description": "Геометрия метки (GeoJSON Point)",
              "children": [
                { "name": "type", "type": "string", "required": true, "description": "Тип геометрии", "enum": ["Point"] },
                { "name": "coordinates", "type": "number[]", "required": true, "description": "Координаты [lon, lat]" }
              ]
            },
            { "name": "photos", "type": "string[]", "required": false, "description": "URL фотографий метки (может отсутствовать, если фото не загружены)" }
          ],
          "example": [
            {
              "id": 42,
              "markName": "Концерт в парке",
              "geom": {
                "type": "Point",
                "coordinates": [37.6176, 55.7558]
              },
              "photos": [
                "https://realtimemap.ru/store/photos/marks/2026/04/photo1.jpg"
              ]
            }
          ]
        },
        {
          "statusCode": 200,
          "description": "Список кластеров (при zoomLevel < 12)",
          "schema": [
            {
              "name": "center",
              "type": "object",
              "required": true,
              "description": "Центр кластера (GeoJSON Point)",
              "children": [
                { "name": "type", "type": "string", "required": true, "description": "Тип геометрии", "enum": ["Point"] },
                { "name": "coordinates", "type": "number[]", "required": true, "description": "Координаты [lon, lat]" }
              ]
            },
            { "name": "count", "type": "integer", "required": true, "description": "Количество меток в кластере" }
          ],
          "example": [
            {
              "center": {
                "type": "Point",
                "coordinates": [37.62, 55.75]
              },
              "count": 15
            }
          ]
        }
      ],
      "errors": ["validation-error"]
    },
    {
      "id": "get-my-marks",
      "method": "GET",
      "path": "/api/v2/marks/my",
      "summary": "Мои метки",
      "description": "Возвращает список меток текущего авторизованного пользователя с пагинацией.",
      "tags": ["Метки"],
      "auth": true,
      "pagination": "page",
      "parameters": [
        { "name": "page", "type": "integer", "required": false, "description": "Номер страницы (по умолчанию 1)", "location": "query", "example": "1" },
        { "name": "pageSize", "type": "integer", "required": false, "description": "Количество элементов на странице (1–100, по умолчанию 10)", "location": "query", "example": "10" }
      ],
      "responses": [
        {
          "statusCode": 200,
          "description": "Список меток пользователя в краткой форме с пагинацией. Для получения деталей конкретной метки используйте `GET /api/v2/marks/{markID}`",
          "schema": [
            {
              "name": "items",
              "type": "object[]",
              "required": true,
              "description": "Массив меток (краткая форма)",
              "children": [
                { "name": "id", "type": "integer", "required": true, "description": "ID метки" },
                { "name": "markName", "type": "string", "required": true, "description": "Название метки" },
                {
                  "name": "geom",
                  "type": "object",
                  "required": true,
                  "description": "Геометрия (GeoJSON Point)",
                  "children": [
                    { "name": "type", "type": "string", "required": true, "description": "Тип геометрии", "enum": ["Point"] },
                    { "name": "coordinates", "type": "number[]", "required": true, "description": "Координаты [lon, lat]" }
                  ]
                },
                { "name": "photos", "type": "string[]", "required": false, "description": "URL фотографий метки" }
              ]
            },
            { "name": "page", "type": "integer", "required": true, "description": "Текущая страница" },
            { "name": "pageSize", "type": "integer", "required": true, "description": "Размер страницы" },
            { "name": "totalPages", "type": "integer", "required": true, "description": "Общее число страниц" },
            { "name": "total", "type": "integer", "required": true, "description": "Общее число меток" },
            { "name": "hasNext", "type": "boolean", "required": true, "description": "Есть ли следующая страница" },
            { "name": "hasPrev", "type": "boolean", "required": true, "description": "Есть ли предыдущая страница" }
          ],
          "example": {
            "items": [
              {
                "id": 42,
                "markName": "Концерт в парке",
                "geom": {
                  "type": "Point",
                  "coordinates": [37.6176, 55.7558]
                },
                "photos": [
                  "https://realtimemap.ru/store/photos/marks/2026/04/photo1.jpg"
                ]
              }
            ],
            "page": 1,
            "pageSize": 10,
            "totalPages": 1,
            "total": 5,
            "hasNext": false,
            "hasPrev": false
          }
        }
      ],
      "errors": ["unauthorized", "validation-error"]
    },
    {
      "id": "detail-mark",
      "method": "GET",
      "path": "/api/v2/marks/{markID}",
      "summary": "Детальная информация о метке",
      "description": "Возвращает полную информацию о конкретной метке по её ID.",
      "tags": ["Метки"],
      "parameters": [
        { "name": "markID", "type": "integer", "required": true, "description": "ID метки", "location": "path", "example": "42" }
      ],
      "responses": [
        {
          "statusCode": 200,
          "description": "Детальная информация о метке",
          "schema": [
            { "name": "id", "type": "integer", "required": true, "description": "ID метки" },
            { "name": "markName", "type": "string", "required": true, "description": "Название метки" },
            { "name": "additionalInfo", "type": "string", "required": false, "description": "Дополнительное описание" },
            {
              "name": "category",
              "type": "object",
              "required": false,
              "description": "Категория метки. Может быть null, если категория удалена",
              "children": [
                { "name": "id", "type": "integer", "required": true, "description": "ID категории" },
                { "name": "categoryName", "type": "string", "required": true, "description": "Название категории" },
                { "name": "color", "type": "string", "required": true, "description": "HEX-цвет категории" },
                { "name": "icon", "type": "string", "required": true, "description": "URL иконки категории" }
              ]
            },
            {
              "name": "geom",
              "type": "object",
              "required": true,
              "description": "Геометрия метки (GeoJSON Point)",
              "children": [
                { "name": "type", "type": "string", "required": true, "description": "Тип геометрии", "enum": ["Point"] },
                { "name": "coordinates", "type": "number[]", "required": true, "description": "Координаты [lon, lat]" }
              ]
            },
            {
              "name": "owner",
              "type": "object",
              "required": true,
              "description": "Владелец метки",
              "children": [
                { "name": "id", "type": "integer", "required": true, "description": "ID пользователя" },
                { "name": "username", "type": "string", "required": true, "description": "Имя пользователя" },
                { "name": "tag", "type": "string", "required": false, "description": "Тег профиля" },
                { "name": "avatar", "type": "string", "required": false, "description": "URL аватара" }
              ]
            },
            { "name": "photos", "type": "string[]", "required": false, "description": "URL фотографий метки" },
            {
              "name": "date",
              "type": "object",
              "required": true,
              "description": "Временные характеристики события и его прогресс",
              "children": [
                { "name": "startAt", "type": "string", "required": true, "description": "Время начала события (ISO 8601)" },
                { "name": "endAt", "type": "string", "required": true, "description": "Время окончания события (ISO 8601)" },
                { "name": "progressPercent", "type": "number", "required": true, "description": "Текущий процент прогресса события (0–100)" },
                { "name": "daysPassed", "type": "integer", "required": true, "description": "Количество дней, прошедших с начала события" },
                { "name": "daysLeft", "type": "integer", "required": true, "description": "Количество дней до окончания события" }
              ]
            },
            {
              "name": "meta",
              "type": "object",
              "required": true,
              "description": "Метаинформация о метке",
              "children": [
                { "name": "status", "type": "string", "required": true, "description": "Текущий статус метки (например, активная / завершённая)" },
                { "name": "markType", "type": "string", "required": true, "description": "Тип метки (определяется на основании временного диапазона и категории)" }
              ]
            }
          ],
          "example": {
            "id": 42,
            "markName": "Концерт в парке",
            "additionalInfo": "Бесплатный вход",
            "category": {
              "id": 1,
              "categoryName": "Мероприятия",
              "color": "#ff5722",
              "icon": "https://realtimemap.ru/store/photos/categories/2026/01/event-icon.png"
            },
            "geom": {
              "type": "Point",
              "coordinates": [37.6176, 55.7558]
            },
            "owner": {
              "id": 5,
              "username": "john_doe",
              "tag": "john",
              "avatar": "https://realtimemap.ru/store/photos/avatars/2026/04/avatar.jpg"
            },
            "photos": [
              "https://realtimemap.ru/store/photos/marks/2026/04/photo1.jpg"
            ],
            "date": {
              "startAt": "2026-04-25T15:32:19.015453Z",
              "endAt": "2026-10-25T15:32:19.015453Z",
              "progressPercent": 4.5,
              "daysPassed": 10,
              "daysLeft": 173
            },
            "meta": {
              "status": "active",
              "markType": "event"
            }
          }
        }
      ],
      "errors": ["validation-error", "not-found"]
    },
    {
      "id": "create-data",
      "method": "GET",
      "path": "/api/v2/marks/create-data",
      "summary": "Данные для создания метки",
      "description": "Возвращает актуальные данные, необходимые для создания метки: доступные категории и допустимые значения длительности (в часах).",
      "tags": ["Утилиты"],
      "responses": [
        {
          "statusCode": 200,
          "description": "Доступные категории и длительности",
          "schema": [
            {
              "name": "allowedCategories",
              "type": "object[]",
              "required": true,
              "description": "Список доступных категорий",
              "children": [
                { "name": "id", "type": "integer", "required": true, "description": "ID категории" },
                { "name": "categoryName", "type": "string", "required": true, "description": "Название категории" },
                { "name": "color", "type": "string", "required": true, "description": "HEX-цвет категории" },
                { "name": "icon", "type": "string", "required": true, "description": "URL иконки категории" }
              ]
            },
            { "name": "allowedDuration", "type": "integer[]", "required": true, "description": "Допустимые длительности метки в часах" }
          ],
          "example": {
            "allowedCategories": [
              {
                "id": 1,
                "categoryName": "Мероприятия",
                "color": "#ff5722",
                "icon": "https://realtimemap.ru/store/photos/categories/2026/01/event-icon.png"
              }
            ],
            "allowedDuration": [12, 24, 36, 48]
          }
        }
      ],
      "errors": []
    },
    {
      "id": "create-mark",
      "method": "POST",
      "path": "/api/v2/marks/create",
      "summary": "Создание метки",
      "description": "Создаёт новую метку на карте. Требуется авторизация. После успешного создания клиенты, подключённые через socket.io, будут оповещены о новой метке.",
      "tags": ["Метки"],
      "auth": true,
      "requestBody": {
        "description": "Данные для создания метки",
        "contentType": "form-data",
        "schema": [
          { "name": "markName", "type": "string", "required": true, "description": "Название метки (3–100 символов)" },
          { "name": "additionalInfo", "type": "string", "required": false, "description": "Дополнительное описание" },
          { "name": "categoryId", "type": "integer", "required": true, "description": "ID активной категории метки" },
          { "name": "startAt", "type": "string", "required": true, "description": "Время начала события (ISO 8601 / RFC3339)" },
          { "name": "endAt", "type": "string", "required": false, "description": "Время окончания события. Если не указано — startAt + 1 час" },
          { "name": "longitude", "type": "number", "required": true, "description": "Долгота (-180 до 180)" },
          { "name": "latitude", "type": "number", "required": true, "description": "Широта (-90 до 90)" },
          { "name": "photos", "type": "file[]", "required": false, "description": "Фотографии метки. До 10 файлов; каждый — до 5 МБ; форматы JPEG, PNG, WebP" }
        ],
        "example": {
          "markName": "Концерт в парке",
          "additionalInfo": "Бесплатный вход",
          "categoryId": 1,
          "startAt": "2026-04-25T18:00:00Z",
          "endAt": "2026-11-25T18:00:00Z",
          "longitude": 37.6176,
          "latitude": 55.7558,
          "photos": "[файлы]"
        }
      },
      "responses": [
        {
          "statusCode": 201,
          "description": "Метка успешно создана. Возвращается краткая форма метки — для деталей используйте `GET /api/v2/marks/{markID}`",
          "schema": [
            { "name": "id", "type": "integer", "required": true, "description": "ID созданной метки" },
            { "name": "markName", "type": "string", "required": true, "description": "Название метки" },
            {
              "name": "geom",
              "type": "object",
              "required": true,
              "description": "Геометрия метки (GeoJSON Point)",
              "children": [
                { "name": "type", "type": "string", "required": true, "description": "Тип геометрии", "enum": ["Point"] },
                { "name": "coordinates", "type": "number[]", "required": true, "description": "Координаты [lon, lat]" }
              ]
            },
            { "name": "photos", "type": "string[]", "required": false, "description": "URL загруженных фотографий" }
          ],
          "example": {
            "id": 42,
            "markName": "Концерт в парке",
            "geom": {
              "type": "Point",
              "coordinates": [37.6176, 55.7558]
            },
            "photos": [
              "https://realtimemap.ru/store/photos/marks/2026/04/photo1.jpg",
              "https://realtimemap.ru/store/photos/marks/2026/04/photo2.jpg"
            ]
          }
        }
      ],
      "errors": ["unauthorized", "validation-error", "not-found", "conflict"]
    },
    {
      "id": "update-mark",
      "method": "PATCH",
      "path": "/api/v2/marks/{markID}",
      "summary": "Обновление метки",
      "description": "Обновляет поля существующей метки. Все поля необязательные — отправляются только те, которые нужно изменить. Можно добавлять новые фото и удалять существующие. Требуется авторизация; обновлять может только владелец или администратор.",
      "tags": ["Метки"],
      "auth": true,
      "parameters": [
        { "name": "markID", "type": "integer", "required": true, "description": "ID метки", "location": "path", "example": "42" }
      ],
      "requestBody": {
        "description": "Поля для обновления (все необязательные)",
        "contentType": "form-data",
        "schema": [
          { "name": "markName", "type": "string", "required": false, "description": "Новое название метки" },
          { "name": "additionalInfo", "type": "string", "required": false, "description": "Новое описание" },
          { "name": "categoryId", "type": "integer", "required": false, "description": "Новый ID категории" },
          { "name": "duration", "type": "integer", "required": false, "description": "Новая длительность в часах. Допустимые значения: 12, 24, 36, 48" },
          { "name": "photos", "type": "file[]", "required": false, "description": "Новые фотографии для добавления" },
          { "name": "photosToDelete", "type": "string[]", "required": false, "description": "URL фотографий для удаления" }
        ],
        "example": {
          "markName": "Обновлённое название",
          "categoryId": 2,
          "photosToDelete": ["https://realtimemap.ru/store/photos/marks/2026/04/old-photo.jpg"]
        }
      },
      "responses": [
        {
          "statusCode": 200,
          "description": "Метка обновлена. Возвращается краткая форма метки — для деталей используйте `GET /api/v2/marks/{markID}`",
          "schema": [
            { "name": "id", "type": "integer", "required": true, "description": "ID метки" },
            { "name": "markName", "type": "string", "required": true, "description": "Название метки" },
            {
              "name": "geom",
              "type": "object",
              "required": true,
              "description": "Геометрия метки (GeoJSON Point)",
              "children": [
                { "name": "type", "type": "string", "required": true, "description": "Тип геометрии", "enum": ["Point"] },
                { "name": "coordinates", "type": "number[]", "required": true, "description": "Координаты [lon, lat]" }
              ]
            },
            { "name": "photos", "type": "string[]", "required": false, "description": "Актуальные URL фотографий" }
          ],
          "example": {
            "id": 42,
            "markName": "Обновлённое название",
            "geom": {
              "type": "Point",
              "coordinates": [37.6176, 55.7558]
            },
            "photos": [
              "https://realtimemap.ru/store/photos/marks/2026/04/photo2.jpg"
            ]
          }
        }
      ],
      "errors": ["unauthorized", "forbidden", "validation-error", "not-found"]
    },
    {
      "id": "delete-mark",
      "method": "DELETE",
      "path": "/api/v2/marks/{markID}",
      "summary": "Удаление метки",
      "description": "Удаляет метку по ID. Требуется авторизация; удалять может только владелец или администратор.",
      "tags": ["Метки"],
      "auth": true,
      "parameters": [
        { "name": "markID", "type": "integer", "required": true, "description": "ID метки", "location": "path", "example": "42" }
      ],
      "responses": [
        {
          "statusCode": 204,
          "description": "Метка успешно удалена"
        }
      ],
      "errors": ["unauthorized", "forbidden", "not-found"]
    },
    {
      "id": "admin-get-all-marks",
      "method": "GET",
      "path": "/api/v2/admin/mark/",
      "summary": "Все метки (админ)",
      "description": "Возвращает все метки с пагинацией. Доступно только администраторам.",
      "tags": ["Админ"],
      "auth": true,
      "pagination": "page",
      "parameters": [
        { "name": "page", "type": "integer", "required": false, "description": "Номер страницы (по умолчанию 1)", "location": "query", "example": "1" },
        { "name": "pageSize", "type": "integer", "required": false, "description": "Количество элементов на странице (1–100, по умолчанию 10)", "location": "query", "example": "10" }
      ],
      "responses": [
        {
          "statusCode": 200,
          "description": "Список всех меток (краткая форма) с пагинацией",
          "schema": [
            {
              "name": "items",
              "type": "object[]",
              "required": true,
              "description": "Массив меток (краткая форма)",
              "children": [
                { "name": "id", "type": "integer", "required": true, "description": "ID метки" },
                { "name": "markName", "type": "string", "required": true, "description": "Название метки" },
                {
                  "name": "geom",
                  "type": "object",
                  "required": true,
                  "description": "Геометрия (GeoJSON Point)",
                  "children": [
                    { "name": "type", "type": "string", "required": true, "description": "Тип геометрии", "enum": ["Point"] },
                    { "name": "coordinates", "type": "number[]", "required": true, "description": "Координаты [lon, lat]" }
                  ]
                },
                { "name": "photos", "type": "string[]", "required": false, "description": "URL фотографий метки" }
              ]
            },
            { "name": "page", "type": "integer", "required": true, "description": "Текущая страница" },
            { "name": "pageSize", "type": "integer", "required": true, "description": "Размер страницы" },
            { "name": "totalPages", "type": "integer", "required": true, "description": "Общее число страниц" },
            { "name": "total", "type": "integer", "required": true, "description": "Общее число меток" },
            { "name": "hasNext", "type": "boolean", "required": true, "description": "Есть ли следующая страница" },
            { "name": "hasPrev", "type": "boolean", "required": true, "description": "Есть ли предыдущая страница" }
          ],
          "example": {
            "items": [
              {
                "id": 42,
                "markName": "Концерт в парке",
                "geom": {
                  "type": "Point",
                  "coordinates": [37.6176, 55.7558]
                },
                "photos": []
              }
            ],
            "page": 1,
            "pageSize": 10,
            "totalPages": 5,
            "total": 48,
            "hasNext": true,
            "hasPrev": false
          }
        }
      ],
      "errors": ["unauthorized", "forbidden"]
    },
    {
      "id": "share-mark",
      "method": "POST",
      "path": "/api/v2/marks/{markID}/share",
      "summary": "Поделиться меткой",
      "description": "Увеличивает счётчик «поделились» (sharedCount) для метки на 1 и возвращает актуальное значение. Авторизация не требуется. Инкремент выполняется атомарно на стороне БД.",
      "tags": ["Метки"],
      "parameters": [
        { "name": "markID", "type": "integer", "required": true, "description": "ID метки", "location": "path", "example": "42" }
      ],
      "responses": [
        {
          "statusCode": 200,
          "description": "Счётчик увеличен. Возвращается новое значение счётчика",
          "schema": [
            { "name": "count", "type": "integer", "required": true, "description": "Актуальное количество «поделились» после инкремента" }
          ],
          "example": {
            "count": 17
          }
        }
      ],
      "errors": ["not-found"]
    },
    {
      "id": "like-mark",
      "method": "POST",
      "path": "/api/v2/marks/{markID}/like",
      "summary": "Поставить лайк метке",
      "description": "Ставит лайк текущего пользователя на метку. Требуется авторизация. Операция идемпотентна — повторный лайк той же метки тем же пользователем не приводит к ошибке и не создаёт дубликат.",
      "tags": ["Метки"],
      "auth": true,
      "parameters": [
        { "name": "markID", "type": "integer", "required": true, "description": "ID метки", "location": "path", "example": "42" }
      ],
      "responses": [
        {
          "statusCode": 200,
          "description": "Лайк поставлен",
          "schema": [
            { "name": "status", "type": "string", "required": true, "description": "Результат операции", "enum": ["ok"] }
          ],
          "example": {
            "status": "ok"
          }
        }
      ],
      "errors": ["unauthorized", "not-found"]
    },
    {
      "id": "create-category",
      "method": "POST",
      "path": "/api/v2/category",
      "summary": "Создание категории",
      "description": "Создаёт новую категорию меток. Доступно только администраторам. Иконка — изображение до 5 МБ (jpeg, png, webp, svg).",
      "tags": ["Категории"],
      "auth": true,
      "requestBody": {
        "description": "Данные категории",
        "contentType": "form-data",
        "schema": [
          { "name": "category_name", "type": "string", "required": true, "description": "Название категории (макс. 64 символа)" },
          { "name": "color", "type": "string", "required": true, "description": "HEX-цвет категории (формат #RRGGBB, макс. 7 символов)" },
          { "name": "icon", "type": "file", "required": true, "description": "Иконка категории (jpeg, png, webp, svg; макс. 5 МБ)" }
        ],
        "example": {
          "category_name": "Мероприятия",
          "color": "#ff5722",
          "icon": "[файл изображения]"
        }
      },
      "responses": [
        {
          "statusCode": 201,
          "description": "Категория создана",
          "schema": [
            { "name": "id", "type": "integer", "required": true, "description": "ID категории" },
            { "name": "categoryName", "type": "string", "required": true, "description": "Название" },
            { "name": "color", "type": "string", "required": true, "description": "HEX-цвет" },
            { "name": "icon", "type": "string", "required": true, "description": "URL иконки" }
          ],
          "example": {
            "id": 3,
            "categoryName": "Мероприятия",
            "color": "#ff5722",
            "icon": "https://realtimemap.ru/store/photos/categories/2026/04/abc123.png"
          }
        }
      ],
      "errors": ["unauthorized", "forbidden", "validation-error", "conflict"]
    },
    {
      "id": "health",
      "method": "GET",
      "path": "/mark/health",
      "summary": "Health-check",
      "description": "Проверка доступности сервиса и подключения к базе данных. Возвращает 200 если БД доступна, иначе 503.",
      "tags": ["Служебные"],
      "responses": [
        {
          "statusCode": 200,
          "description": "Сервис и БД работают",
          "schema": [
            { "name": "status", "type": "string", "required": true, "description": "Состояние сервиса", "enum": ["healthy"] },
            { "name": "service", "type": "string", "required": true, "description": "Имя сервиса" }
          ],
          "example": {
            "status": "healthy",
            "service": "mark-service"
          }
        },
        {
          "statusCode": 503,
          "description": "БД недоступна",
          "schema": [
            { "name": "status", "type": "string", "required": true, "description": "Состояние сервиса", "enum": ["unhealthy"] },
            { "name": "service", "type": "string", "required": true, "description": "Имя сервиса" }
          ],
          "example": {
            "status": "unhealthy",
            "service": "mark-service"
          }
        }
      ],
      "errors": []
    }
  ]
}
