{
  "endpoints": [
    {
      "id": "get-my-profile",
      "method": "GET",
      "path": "/api/v2/profile/me",
      "summary": "Получить свой профиль",
      "description": "Возвращает профиль текущего авторизованного пользователя с настройками приватности и данными геймификации (если gamification-service доступен). Требуется авторизация.",
      "tags": ["Профили"],
      "auth": true,
      "parameters": [],
      "responses": [
        {
          "statusCode": 200,
          "description": "Персональный профиль пользователя",
          "schema": [
            { "name": "userId", "type": "integer", "required": true, "description": "ID пользователя" },
            { "name": "username", "type": "string", "required": true, "description": "Имя пользователя" },
            { "name": "avatar", "type": "string", "required": false, "description": "URL аватара" },
            { "name": "isPrivate", "type": "boolean", "required": true, "description": "Приватный ли профиль" },
            {
              "name": "settings",
              "type": "object",
              "required": true,
              "description": "Настройки приватности",
              "children": [
                { "name": "showInSearch", "type": "boolean", "required": true, "description": "Показывать профиль в поиске" }
              ]
            },
            {
              "name": "gamification",
              "type": "object",
              "required": false,
              "description": "Данные геймификации. Может отсутствовать, если gamification-service недоступен",
              "children": [
                { "name": "currentLevel", "type": "integer", "required": true, "description": "Текущий уровень пользователя" },
                { "name": "currentXp", "type": "integer", "required": true, "description": "Текущее количество накопленного опыта" },
                { "name": "xpForNextLevel", "type": "integer", "required": true, "description": "Опыт, необходимый для перехода на следующий уровень" },
                { "name": "progressPercent", "type": "number", "required": true, "description": "Процент прогресса до следующего уровня" }
              ]
            }
          ],
          "example": {
            "userId": 1,
            "username": "john_doe",
            "avatar": "https://realtimemap.ru/store/profile-avatars/2026/04/avatar.jpg",
            "isPrivate": false,
            "settings": {
              "showInSearch": true
            },
            "gamification": {
              "currentLevel": 5,
              "currentXp": 1500,
              "xpForNextLevel": 2000,
              "progressPercent": 75.0
            }
          }
        }
      ],
      "errors": ["unauthorized", "not-found"]
    },
    {
      "id": "update-my-profile",
      "method": "PATCH",
      "path": "/api/v2/profile/me",
      "summary": "Обновить свой профиль",
      "description": "Обновляет профиль текущего пользователя: имя пользователя, тег и аватар. Все поля необязательные. Требуется авторизация.",
      "tags": ["Профили"],
      "auth": true,
      "requestBody": {
        "description": "Поля профиля для обновления (все необязательные)",
        "contentType": "form-data",
        "schema": [
          { "name": "username", "type": "string", "required": false, "description": "Новое имя пользователя (2–32 символа)" },
          { "name": "tag", "type": "string", "required": false, "description": "Новый тег профиля" },
          { "name": "avatar", "type": "file", "required": false, "description": "Файл нового аватара (изображение, до 5 МБ)" }
        ],
        "example": {
          "username": "john_doe_updated",
          "tag": "johndoe"
        }
      },
      "responses": [
        {
          "statusCode": 200,
          "description": "Обновлённый профиль (без секции gamification)",
          "schema": [
            { "name": "userId", "type": "integer", "required": true, "description": "ID пользователя" },
            { "name": "username", "type": "string", "required": true, "description": "Имя пользователя" },
            { "name": "avatar", "type": "string", "required": false, "description": "URL аватара" },
            { "name": "isPrivate", "type": "boolean", "required": true, "description": "Приватный ли профиль" },
            {
              "name": "settings",
              "type": "object",
              "required": true,
              "description": "Настройки приватности",
              "children": [
                { "name": "showInSearch", "type": "boolean", "required": true, "description": "Показывать профиль в поиске" }
              ]
            }
          ],
          "example": {
            "userId": 1,
            "username": "john_doe_updated",
            "avatar": "https://realtimemap.ru/store/profile-avatars/2026/05/new-avatar.jpg",
            "isPrivate": false,
            "settings": {
              "showInSearch": true
            }
          }
        }
      ],
      "errors": ["unauthorized", "validation-error", "conflict", "not-found"]
    },
    {
      "id": "search-profile",
      "method": "GET",
      "path": "/api/v2/profile/search",
      "summary": "Поиск профилей",
      "description": "Поиск профилей пользователей по username (поиск по подстроке). Возвращаются только профили с включённой настройкой showInSearch. Если параметр q не задан, возвращаются случайные публичные профили. Авторизация не требуется.",
      "tags": ["Профили"],
      "pagination": "page",
      "parameters": [
        { "name": "q", "type": "string", "required": false, "description": "Поисковый запрос по username (подстрока)", "location": "query", "example": "admin" },
        { "name": "page", "type": "integer", "required": false, "description": "Номер страницы (по умолчанию 1)", "location": "query", "example": "1" },
        { "name": "pageSize", "type": "integer", "required": false, "description": "Размер страницы (1–100, по умолчанию 10)", "location": "query", "example": "10" }
      ],
      "responses": [
        {
          "statusCode": 200,
          "description": "Список профилей с пагинацией",
          "schemaRef": "profile",
          "example": {
            "items": [
              { "userId": 4, "username": "base", "avatar": "", "isPrivate": false },
              { "userId": 3, "username": "admin", "avatar": "", "isPrivate": false }
            ],
            "page": 1,
            "pageSize": 10,
            "totalPages": 1,
            "total": 2,
            "hasNext": false,
            "hasPrev": false
          }
        }
      ],
      "errors": ["validation-error"]
    },
    {
      "id": "get-detail-profile",
