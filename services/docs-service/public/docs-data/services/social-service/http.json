{
  "endpoints": [
    {
      "id": "get-my-profile",
      "method": "GET",
      "path": "/api/v2/profile/me",
      "summary": "Получить свой профиль",
      "description": "Возвращает профиль текущего авторизованного пользователя с настройками приватности и данными геймификации (если gamification-service доступен). Требуется авторизация.",
      "tags": ["Профили"],
      "auth": true,
      "parameters": [],
      "responses": [
        {
          "statusCode": 200,
          "description": "Персональный профиль пользователя",
          "schema": [
            { "name": "userId", "type": "integer", "required": true, "description": "ID пользователя" },
            { "name": "username", "type": "string", "required": true, "description": "Имя пользователя" },
            { "name": "avatar", "type": "string", "required": false, "description": "URL аватара" },
            { "name": "isPrivate", "type": "boolean", "required": true, "description": "Приватный ли профиль" },
            {
              "name": "settings",
              "type": "object",
              "required": true,
              "description": "Настройки приватности",
              "children": [
                { "name": "showInSearch", "type": "boolean", "required": true, "description": "Показывать профиль в поиске" }
              ]
            },
            {
              "name": "gamification",
              "type": "object",
              "required": false,
              "description": "Данные геймификации. Может отсутствовать, если gamification-service недоступен",
              "children": [
                { "name": "currentLevel", "type": "integer", "required": true, "description": "Текущий уровень пользователя" },
                { "name": "currentXp", "type": "integer", "required": true, "description": "Текущее количество накопленного опыта" },
                { "name": "xpForNextLevel", "type": "integer", "required": true, "description": "Опыт, необходимый для перехода на следующий уровень" },
                { "name": "progressPercent", "type": "number", "required": true, "description": "Процент прогресса до следующего уровня" }
              ]
            }
          ],
          "example": {
            "userId": 1,
            "username": "john_doe",
            "avatar": "https://realtimemap.ru/store/profile-avatars/2026/04/avatar.jpg",
            "isPrivate": false,
            "settings": {
              "showInSearch": true
            },
            "gamification": {
              "currentLevel": 5,
              "currentXp": 1500,
              "xpForNextLevel": 2000,
              "progressPercent": 75.0
            }
          }
        }
      ],
      "errors": ["unauthorized", "not-found"]
    },
    {
      "id": "update-my-profile",
      "method": "PATCH",
      "path": "/api/v2/profile/me",
      "summary": "Обновить свой профиль",
      "description": "Обновляет профиль текущего пользователя: имя пользователя, тег и аватар. Все поля необязательные. Требуется авторизация.",
      "tags": ["Профили"],
      "auth": true,
      "requestBody": {
        "description": "Поля профиля для обновления (все необязательные)",
        "contentType": "form-data",
        "schema": [
          { "name": "username", "type": "string", "required": false, "description": "Новое имя пользователя (2–32 символа)" },
          { "name": "tag", "type": "string", "required": false, "description": "Новый тег профиля" },
          { "name": "avatar", "type": "file", "required": false, "description": "Файл нового аватара (изображение, до 5 МБ)" }
        ],
        "example": {
          "username": "john_doe_updated",
          "tag": "johndoe"
        }
      },
      "responses": [
        {
          "statusCode": 200,
          "description": "Обновлённый профиль (без секции gamification)",
          "schema": [
            { "name": "userId", "type": "integer", "required": true, "description": "ID пользователя" },
            { "name": "username", "type": "string", "required": true, "description": "Имя пользователя" },
            { "name": "avatar", "type": "string", "required": false, "description": "URL аватара" },
            { "name": "isPrivate", "type": "boolean", "required": true, "description": "Приватный ли профиль" },
            {
              "name": "settings",
              "type": "object",
              "required": true,
              "description": "Настройки приватности",
              "children": [
                { "name": "showInSearch", "type": "boolean", "required": true, "description": "Показывать профиль в поиске" }
              ]
            }
          ],
          "example": {
            "userId": 1,
            "username": "john_doe_updated",
            "avatar": "https://realtimemap.ru/store/profile-avatars/2026/05/new-avatar.jpg",
            "isPrivate": false,
            "settings": {
              "showInSearch": true
            }
          }
        }
      ],
      "errors": ["unauthorized", "validation-error", "conflict", "not-found"]
    },
    {
      "id": "search-profile",
      "method": "GET",
      "path": "/api/v2/profile/search",
      "summary": "Поиск профилей",
      "description": "Поиск профилей пользователей по username (поиск по подстроке). Возвращаются только профили с включённой настройкой showInSearch. Если параметр q не задан, возвращаются случайные публичные профили. Авторизация не требуется.",
      "tags": ["Профили"],
      "pagination": "page",
      "parameters": [
        { "name": "q", "type": "string", "required": false, "description": "Поисковый запрос по username (подстрока)", "location": "query", "example": "admin" },
        { "name": "page", "type": "integer", "required": false, "description": "Номер страницы (по умолчанию 1)", "location": "query", "example": "1" },
        { "name": "pageSize", "type": "integer", "required": false, "description": "Размер страницы (1–100, по умолчанию 10)", "location": "query", "example": "10" }
      ],
      "responses": [
        {
          "statusCode": 200,
          "description": "Список профилей с пагинацией",
          "schemaRef": "profile",
          "example": {
            "items": [
              { "userId": 4, "username": "base", "avatar": "", "isPrivate": false },
              { "userId": 3, "username": "admin", "avatar": "", "isPrivate": false }
            ],
            "page": 1,
            "pageSize": 10,
            "totalPages": 1,
            "total": 2,
            "hasNext": false,
            "hasPrev": false
          }
        }
      ],
      "errors": ["validation-error"]
    },
    {
      "id": "get-detail-profile",
      "method": "GET",
      "path": "/api/v2/profile/{profileID}",
      "summary": "Получить профиль по ID",
      "description": "Возвращает полный профиль пользователя с данными геймификации (если доступны). Публичный endpoint.",
      "tags": ["Профили"],
      "parameters": [
        { "name": "profileID", "type": "integer", "required": true, "description": "ID пользователя", "location": "path", "example": "1" }
      ],
      "responses": [
        {
          "statusCode": 200,
          "description": "Профиль пользователя",
          "schema": [
            { "name": "userId", "type": "integer", "required": true, "description": "ID пользователя" },
            { "name": "username", "type": "string", "required": true, "description": "Имя пользователя" },
            { "name": "avatar", "type": "string", "required": false, "description": "URL аватара" },
            { "name": "isPrivate", "type": "boolean", "required": true, "description": "Приватный ли профиль" },
            {
              "name": "settings",
              "type": "object",
              "required": true,
              "description": "Настройки приватности",
              "children": [
                { "name": "showInSearch", "type": "boolean", "required": true, "description": "Показывать профиль в поиске" }
              ]
            },
            {
              "name": "gamification",
              "type": "object",
              "required": false,
              "description": "Данные геймификации (могут отсутствовать)",
              "children": [
                { "name": "currentLevel", "type": "integer", "required": true, "description": "Текущий уровень пользователя" },
                { "name": "currentXp", "type": "integer", "required": true, "description": "Текущий накопленный опыт" },
                { "name": "xpForNextLevel", "type": "integer", "required": true, "description": "Опыт для следующего уровня" },
                { "name": "progressPercent", "type": "number", "required": true, "description": "Процент прогресса" }
              ]
            }
          ],
          "example": {
            "userId": 1,
            "username": "john_doe",
            "avatar": "https://realtimemap.ru/store/profile-avatars/2026/04/avatar.jpg",
            "isPrivate": false,
            "settings": {
              "showInSearch": true
            },
            "gamification": {
              "currentLevel": 5,
              "currentXp": 1500,
              "xpForNextLevel": 2000,
              "progressPercent": 75.0
            }
          }
        }
      ],
      "errors": ["validation-error", "not-found"]
    },
    {
      "id": "block-user",
      "method": "POST",
      "path": "/api/v2/friends/block",
      "summary": "Заблокировать пользователя",
      "description": "Блокирует указанного пользователя. Нельзя заблокировать самого себя или уже заблокированного пользователя. Требуется авторизация.",
      "tags": ["Блокировки"],
      "auth": true,
      "parameters": [],
      "requestBody": {
        "description": "ID пользователя для блокировки",
        "contentType": "json",
        "schema": [
          { "name": "UserId", "type": "integer", "required": true, "description": "ID пользователя для блокировки" }
        ],
        "example": {
          "UserId": 5
        }
      },
      "responses": [
        {
          "statusCode": 204,
          "description": "Пользователь успешно заблокирован"
        }
      ],
      "errors": ["unauthorized", "validation-error", "conflict", "not-found"]
    },
    {
      "id": "unblock-user",
      "method": "POST",
      "path": "/api/v2/friends/unblock",
      "summary": "Разблокировать пользователя",
      "description": "Снимает блокировку с указанного пользователя. Требуется авторизация.",
      "tags": ["Блокировки"],
      "auth": true,
      "parameters": [],
      "requestBody": {
        "description": "ID пользователя для разблокировки",
        "contentType": "json",
        "schema": [
          { "name": "UserId", "type": "integer", "required": true, "description": "ID пользователя для разблокировки" }
        ],
        "example": {
          "UserId": 5
        }
      },
      "responses": [
        {
          "statusCode": 204,
          "description": "Пользователь успешно разблокирован"
        }
      ],
      "errors": ["unauthorized", "validation-error", "not-found"]
    },
    {
      "id": "get-blocked-users",
      "method": "GET",
      "path": "/api/v2/friends/blocked",
      "summary": "Список заблокированных пользователей",
      "description": "Возвращает список профилей заблокированных пользователей с пагинацией. Требуется авторизация.",
      "tags": ["Блокировки"],
      "auth": true,
      "pagination": "page",
      "parameters": [
        { "name": "q", "type": "string", "required": false, "description": "Поисковый запрос (зарезервирован)", "location": "query" },
        { "name": "page", "type": "integer", "required": false, "description": "Номер страницы (по умолчанию 1)", "location": "query", "example": "1" },
        { "name": "pageSize", "type": "integer", "required": false, "description": "Размер страницы (1–100, по умолчанию 10)", "location": "query", "example": "10" }
      ],
      "responses": [
        {
          "statusCode": 200,
          "description": "Список заблокированных профилей с пагинацией",
          "schemaRef": "profile",
          "example": {
            "items": [
              { "userId": 5, "username": "blocked_user", "avatar": "", "isPrivate": false }
            ],
            "page": 1,
            "pageSize": 10,
            "totalPages": 1,
            "total": 1,
            "hasNext": false,
            "hasPrev": false
          }
        }
      ],
      "errors": ["unauthorized", "validation-error"]
    },
    {
      "id": "health",
      "method": "GET",
      "path": "/social/health",
      "summary": "Health-check",
      "description": "Проверка доступности сервиса и подключения к базе данных.",
      "tags": ["Служебные"],
      "responses": [
        {
          "statusCode": 200,
          "description": "Сервис и БД работают",
          "schema": [
            { "name": "status", "type": "string", "required": true, "description": "Состояние сервиса", "enum": ["healthy"] },
            { "name": "service", "type": "string", "required": true, "description": "Имя сервиса" }
          ],
          "example": {
            "status": "healthy",
            "service": "social-service"
          }
        },
        {
          "statusCode": 503,
          "description": "БД недоступна",
          "schema": [
            { "name": "status", "type": "string", "required": true, "description": "Состояние сервиса", "enum": ["unhealthy"] },
            { "name": "service", "type": "string", "required": true, "description": "Имя сервиса" }
          ],
          "example": {
            "status": "unhealthy",
            "service": "social-service"
          }
        }
      ],
      "errors": []
    },
    {
      "id": "get-summary-stat",
      "method": "GET",
      "path": "/api/v2/profile/{profileID}/summary",
      "summary": "Сводная статистика профиля",
      "description": "Возвращает 3 численных значения статистики профиля: общее количество созданных пользователем меток, количество друзей и количество подписчиков. Авторизация не требуется.",
      "tags": ["Профили", "Статистика"],
      "parameters": [
        { "name": "profileID", "type": "integer", "required": true, "description": "ID профиля", "location": "path", "example": "42" }
      ],
      "responses": [
        {
          "statusCode": 200,
          "description": "Сводная статистика",
          "schema": [
            { "name": "markCount", "type": "integer", "required": true, "description": "Общее количество созданных меток" },
            { "name": "friendsCount", "type": "integer", "required": true, "description": "Общее количество друзей" },
            { "name": "subscribersCount", "type": "integer", "required": true, "description": "Общее количество подписчиков" }
          ],
          "example": {
            "markCount": 27,
            "friendsCount": 14,
            "subscribersCount": 102
          }
        }
      ],
      "errors": ["validation-error", "not-found"]
    },
    {
      "id": "statistic",
      "method": "GET",
      "path": "/api/v2/statistic/",
      "summary": "Сводная статистика по периоду",
      "description": "Технический endpoint, возвращающий разрешённые границы периода (текущий и предыдущий) для сводных дашбордов. Период задаётся через query-параметры из общего набора `pkg/date.Query` (например, `period=week`). На текущий момент возвращает только метаданные периода, без агрегатов — используется фронтендом для синхронизации временных диапазонов.",
      "tags": ["Статистика"],
      "parameters": [
        { "name": "period", "type": "string", "required": false, "description": "Шорткат периода (например, 'day', 'week', 'month', 'year')", "location": "query", "example": "week" },
        { "name": "start", "type": "string", "required": false, "description": "Начало периода (ISO 8601). Используется вместе с `end`", "location": "query", "example": "2026-04-01T00:00:00Z" },
        { "name": "end", "type": "string", "required": false, "description": "Конец периода (ISO 8601). Используется вместе с `start`", "location": "query", "example": "2026-04-30T23:59:59Z" }
      ],
      "responses": [
        {
          "statusCode": 200,
          "description": "Границы текущего и предыдущего периода",
          "schema": [
            { "name": "status", "type": "string", "required": true, "description": "Статус ответа", "enum": ["ok"] },
            { "name": "currentStart", "type": "string", "required": true, "description": "Начало текущего периода (ISO 8601)" },
            { "name": "currentEnd", "type": "string", "required": true, "description": "Конец текущего периода (ISO 8601)" },
            { "name": "previousStart", "type": "string", "required": true, "description": "Начало предыдущего периода (ISO 8601)" },
            { "name": "previousEnd", "type": "string", "required": true, "description": "Конец предыдущего периода (ISO 8601)" }
          ],
          "example": {
            "status": "ok",
            "currentStart": "2026-04-28T00:00:00Z",
            "currentEnd": "2026-05-05T00:00:00Z",
            "previousStart": "2026-04-21T00:00:00Z",
            "previousEnd": "2026-04-28T00:00:00Z"
          }
        }
      ],
      "errors": ["validation-error"]
    }
  ]
}
