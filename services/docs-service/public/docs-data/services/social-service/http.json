        ],
        "example": {
          "UserId": 5
        }
      },
      "responses": [
        {
          "statusCode": 204,
          "description": "Заявка в друзья успешно отправлена"
        }
      ],
      "errors": ["unauthorized", "validation-error", "conflict", "forbidden", "not-found"]
    },
