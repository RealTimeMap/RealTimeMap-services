    {
      "id": "get-summary-stat",
      "method": "GET",
      "path": "/api/v2/profile/{profileID}/statistics/summary",
      "summary": "Сводная статистика профиля",
      "description": "Возвращает 3 численных значения статистики профиля: общее количество созданных пользователем меток, количество друзей и количество подписчиков. Значения проходят через пороговое преобразование (`utils.Threshold`), поэтому возвращаются как числа с плавающей точкой. Авторизация не требуется. Перед обработкой проверяется существование профиля по `profileID`.",
      "tags": ["Профили", "Статистика"],
      "parameters": [
        { "name": "profileID", "type": "integer", "required": true, "description": "ID профиля", "location": "path", "example": "42" }
      ],
      "responses": [
        {
          "statusCode": 200,
          "description": "Сводная статистика",
          "schema": [
            { "name": "markCount", "type": "number", "required": true, "description": "Общее количество созданных меток (с пороговым округлением)" },
            { "name": "friendsCount", "type": "string", "required": true, "description": "Общее количество друзей (с пороговым округлением)" },
            { "name": "subscribersCount", "type": "string", "required": true, "description": "Общее количество подписчиков (с пороговым округлением)" }
          ],
          "example": {
            "markCount": 27,
            "friendsCount": "14",
            "subscribersCount": "1.5 K"
          }
        }
      ],
      "errors": ["validation-error", "not-found"]
    },
    {
      "id": "get-monthly-stat",
      "method": "GET",
      "path": "/api/v2/profile/{profileID}/statistics/monthly",
      "summary": "Статистика активности меток по месяцам",
      "description": "Возвращает 12 объектов — по одному на каждый месяц текущего года. Для каждого месяца возвращается полное название, короткое название (первые 3 символа) и количество созданных пользователем меток. Год берётся серверным временем (текущий календарный год), параметром не задаётся. Данные подтягиваются из mark-service по gRPC. Авторизация не требуется. Перед обработкой проверяется существование профиля по `profileID`.",
      "tags": ["Профили", "Статистика"],
      "parameters": [
        { "name": "profileID", "type": "integer", "required": true, "description": "ID профиля", "location": "path", "example": "42" }
      ],
      "responses": [
        {
          "statusCode": 200,
          "description": "Массив помесячной активности (12 элементов, январь → декабрь)",
          "schema": [
            {
              "name": "[]",
              "type": "array",
              "required": true,
              "description": "Список объектов помесячной активности",
              "children": [
                { "name": "month", "type": "string", "required": true, "description": "Полное название месяца (например, 'January')" },
