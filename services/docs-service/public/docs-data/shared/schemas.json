{
  "schemas": {
    "profile": {
      "id": "profile",
      "name": "Профиль пользователя",
      "description": "Базовая информация о профиле пользователя",
      "fields": [
        { "name": "userId", "type": "integer", "required": true, "description": "ID пользователя" },
        { "name": "username", "type": "string", "required": true, "description": "Имя пользователя" },
        { "name": "avatar", "type": "string", "required": false, "description": "URL аватара" },
        { "name": "isPrivate", "type": "boolean", "required": true, "description": "Приватный ли профиль" }
      ]
    },
    "personal-profile": {
      "id": "personal-profile",
      "name": "Персональный профиль",
      "description": "Профиль текущего пользователя с настройками приватности",
      "fields": [
        { "name": "userId", "type": "integer", "required": true, "description": "ID пользователя" },
        { "name": "username", "type": "string", "required": true, "description": "Имя пользователя" },
        { "name": "avatar", "type": "string", "required": false, "description": "URL аватара" },
        { "name": "isPrivate", "type": "boolean", "required": true, "description": "Приватный ли профиль" },
        {
          "name": "settings",
          "type": "object",
          "required": true,
          "description": "Настройки приватности",
          "children": [
            { "name": "showInSearch", "type": "boolean", "required": true, "description": "Показывать профиль в поиске" }
          ]
        }
      ]
    },
    "token-pair": {
      "id": "token-pair",
      "name": "Пара JWT-токенов",
      "description": "Access и refresh токены для авторизации",
      "fields": [
        { "name": "accessToken", "type": "string", "required": true, "description": "JWT access token" },
        { "name": "refreshToken", "type": "string", "required": true, "description": "JWT refresh token" }
      ]
    },
    "user": {
      "id": "user",
      "name": "Пользователь",
      "description": "Данные пользователя",
      "fields": [
        { "name": "id", "type": "string", "required": true, "description": "UUID пользователя" },
        { "name": "email", "type": "string", "required": true, "description": "Email пользователя" },
        { "name": "username", "type": "string", "required": true, "description": "Имя пользователя" }
      ]
    }
  }
}
